   "source": [
    "# Messwerte in Celsius\n",
    "celsius_werte = [0, 10, 20, 30, 100]\n",
    "\n",
    "# Umrechnung in Kelvin\n",
    "# Formel: T_Kelvin = T_Celsius + 273.15\n",
    "for temp in celsius_werte:\n",
    "    kelvin = temp + 273.15\n",
    "    print(f\"{temp} Grad Celsius sind {kelvin} Kelvin\")"
   ]
  },
